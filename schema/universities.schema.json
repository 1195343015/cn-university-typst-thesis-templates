{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.com/schemas/universities.schema.json",
  "title": "Mainland China University Thesis Typst Template Collection",
  "type": "array",
  "items": {
    "type": "object",
    "required": [
      "school_id",
      "school_name_zh",
      "templates"
    ],
    "properties": {
      "school_id": {
        "type": "string",
        "pattern": "^[a-z0-9-]+$"
      },
      "school_name_zh": {
        "type": "string",
        "minLength": 1
      },
      "templates": {
        "type": "array",
        "items": {
          "type": "object",
          "required": [
            "repo",
            "degree_types",
            "github_metrics"
          ],
          "properties": {
            "repo": {
              "type": "string",
              "pattern": "^[A-Za-z0-9_.-]+\\/[A-Za-z0-9_.-]+$"
            },
            "degree_types": {
              "type": "array",
              "minItems": 1,
              "items": {
                "type": "string",
                "enum": [
                  "undergraduate",
                  "master",
                  "doctoral"
                ]
              }
            },
            "github_metrics": {
              "type": "object",
              "required": [
                "stars",
                "last_commit_at",
                "last_synced_at"
              ],
              "properties": {
                "stars": {
                  "type": "integer",
                  "minimum": 0
                },
                "last_commit_at": {
                  "type": "string",
                  "format": "date-time"
                },
                "last_synced_at": {
                  "type": "string",
                  "format": "date-time"
                }
              },
              "additionalProperties": false
            }
          },
          "additionalProperties": false
        }
      }
    },
    "additionalProperties": false
  }
}
